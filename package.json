{
  "name": "@tarasrushchak/storyblok-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Storyblok CMS integration - components, stories, assets, spaces management",
  "main": "dist/server.js",
  "bin": {
    "storyblok-mcp-server": "dist/server.js"
  },
  "type": "module",
  "files": [
    "dist",
    "LICENSE.txt",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "NODE_NO_WARNINGS=1 node --loader ts-node/esm src/server.ts",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "keywords": [
    "mcp",
    "storyblok",
    "cms",
    "headless-cms",
    "model-context-protocol",
    "ai",
    "llm"
  ],
  "author": "Taras Rushchak",
  "license": "GPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/TarasKhust/storyblok-mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "axios": "^1.8.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
